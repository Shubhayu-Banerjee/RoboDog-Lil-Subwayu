<?xml version='1.0' encoding='UTF-8'?>
<robot name="robo_dog">

  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
  <material name="green"><color rgba="0.0 0.8 0.0 1.0"/></material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.35 0.15 0.10"/>
      </geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="1.5"/> 
      <inertia ixx="0.0040625" ixy="0" ixz="0" iyy="0.0165625" iyz="0" izz="0.018125"/>
    </inertial>
  </link>

  <joint name="FR_hip_roll_joint" type="revolute">
    <parent link="base_link"/>
    <child link="FR_hip_intermediate"/>
    <origin xyz="0.14875 -0.09375 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/> <limit effort="10.0" lower="-0.7854" upper="0.7854" velocity="3.0"/> </joint>

  <link name="FR_hip_intermediate">
    <inertial>
      <mass value="0.05"/> <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="FR_hip_joint" type="revolute">
    <parent link="FR_hip_intermediate"/>
    <child link="FR_thigh"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit effort="10.0" lower="-2.09" upper="1.04" velocity="3.0"/>
  </joint>

  <link name="FR_thigh">
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.10"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="FR_knee_joint" type="revolute">
    <parent link="FR_thigh"/>
    <child link="FR_calf"/>
    <origin xyz="0 0 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> 
    <limit effort="10.0" lower="0.35" upper="2.61" velocity="3.0"/>
  </joint>

  <link name="FR_calf">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.12"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision> 
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.12"/>
